            bindings =
            <&ak_p2>,
            <&macro_release>,
            <&kp LSHFT>,
            <&macro_release>,
            <&kp RSHFT>,
            <&macro_tap>,
            <&kp H>;

            label = "PH";
        };

        findsel: findsel {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
            <&macro_tap>,
            <&kp LC(C)>,
            <&macro_tap>,
            <&kp LC(F)>,
            <&macro_tap>,
            <&kp LC(V)>,
            <&macro_tap>,
            <&kp RETURN>,
            <&macro_tap>,
            <&kp LC(G)>;

