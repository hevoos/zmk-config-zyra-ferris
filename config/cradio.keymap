    // Maybe add require-idle-ms 150 for horizontal combos and change timeout-ms to 30 for vertical and idle to 50 as per urob

    combos {
        compatible = "zmk,combos";
    //    timeout-ms = <20>;

        m_enter {
            bindings = <&kp ENTER>;
            key-positions = <16 17 18>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        th {
            bindings = <&th>;
            key-positions = <12 13>;
            timeout-ms = <20>;
        };

        left_par {
            bindings = <&kp LEFT_PARENTHESIS>;
            key-positions = <16 17>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        right_par {
            bindings = <&kp RIGHT_PARENTHESIS>;
            key-positions = <17 18>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        // equals {
        //     bindings = <&kp EQUAL>;
        //     key-positions = <18 19>;
        //     timeout-ms = <20>;
        // };

        colon {
            bindings = <&kp COLON>;
            key-positions = <16 18>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        curvy {
            bindings = <&kp TILDE>;
            key-positions = <25 29>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        underscore {
            bindings = <&kp UNDER>;
            key-positions = <28 26>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        snabela {
            bindings = <&kp AT>;
            key-positions = <5 6>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        tab {
            bindings = <&kp TAB>;
            key-positions = <0 1>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        Stab {
            bindings = <&kp LS(TAB)>;
            key-positions = <0 1 2>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        space {
            bindings = <&kp SPACE>;
            key-positions = <13 14>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        escape {
            bindings = <&kp ESCAPE>;
            key-positions = <10 13>;
            timeout-ms = <20>;
