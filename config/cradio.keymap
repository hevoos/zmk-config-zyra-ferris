            key-positions = <20 23>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        undo {
            bindings = <&kp LC(Z)>;
            key-positions = <20 21 22>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        redo {
            bindings = <&kp LC(LS(Z))>;
            key-positions = <20 21 22 23>;
            timeout-ms = <20>;
            require-prior-idle-ms = <150>;
        };

        quit {
