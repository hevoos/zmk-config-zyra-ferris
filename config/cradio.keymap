        // Plain adaptive-key for T (no mod), used only as the first step inside digraph macros
        ak_t: ak_t {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp T>;

            akt_t_comma {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(T)>;
                max-prior-idle-ms = <500>;
                strict-modifiers;
            };
        };

        ak_c: ak_c {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp C>;

            akt_c_comma {
