    // Maybe add timing to digraph macros - tap-ms = 10 (is the value that HD creator uses.)

    macros {
        comma_cap_s: comma_cap_s {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(S)>;
            label = "COMMA_CAP_S";
        };

        comma_cap_c: comma_cap_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(C)>;
            label = "COMMA_CAP_C";
        };

        comma_cap_n: comma_cap_n {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(N)>;
            label = "COMMA_CAP_N";
        };

        comma_cap_t: comma_cap_t {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(T)>;
            label = "COMMA_CAP_T";
        };

        comma_cap_a: comma_cap_a {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(A)>;
            label = "COMMA_CAP_A";
        };

        comma_cap_e: comma_cap_e {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(E)>;
            label = "COMMA_CAP_E";
        };

        comma_cap_i: comma_cap_i {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(I)>;
            label = "COMMA_CAP_I";
        };

        comma_cap_h: comma_cap_h {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp LS(H)>;
            label = "COMMA_CAP_H";
        };

        ae_umlaut: ae_umlaut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RA(A)>;
            label = "AE_UMLAUT";
        };

        aa_umlaut: aa_umlaut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RA(W)>;
