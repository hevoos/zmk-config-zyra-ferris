            label = "IVE";
        };

        youve: youve {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
            <&kp Y>,
            <&macro_release>,
            <&kp LSHFT>,
            <&macro_release>,
            <&kp RSHFT>,
            <&macro_tap>,
            <&kp O &kp U &kp APOSTROPHE &kp V &kp E &kp SPACE>;

            label = "YOUVE";
        };

        youre: youre {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
            <&kp Y>,
            <&macro_release>,
            <&kp LSHFT>,
            <&macro_release>,
            <&kp RSHFT>,
            <&macro_tap>,
            <&kp O &kp U &kp APOSTROPHE &kp R &kp E &kp SPACE>;

            label = "YOURE";
        };

        youd: youd {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
            <&kp Y>,
            <&macro_release>,
            <&kp LSHFT>,
            <&macro_release>,
            <&kp RSHFT>,
            <&macro_tap>,
            <&kp O &kp U &kp APOSTROPHE &kp D &kp SPACE>;

            label = "YOUD";
        };

        youll: youll {
            compatible = "zmk,behavior-macro";
