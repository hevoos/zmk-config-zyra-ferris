#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

// Using Urob's timeless homerow mods

// Trying to make sure that sticky shift only shifts one key after being pressed.

&sk {
    release-after-ms = <1000>;
    quick-release;
};

// Faster mouse movements

#define ZMK_POINTING_DEFAULT_MOVE_VAL 1500  // default: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 20    // default: 10

/ {
    behaviors {
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <0 1 2 3 4 10 11 12 13 14 20 21 22 23 24 30 31>; // List of keys on the right side of the keyboard
            hold-trigger-on-release;
        };

        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <5 6 7 8 9 15 16 17 18 19 25 26 27 28 29 32 33>; // List of keys on the left side of the keyboard
            hold-trigger-on-release;
        };

        // Comma Magic for homerow-mod S: tap after comma = capital S, hold = mod (unaffected)
        ak_hml_s: ak_hml_s {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hml LEFT_GUI S>;

            akt_comma_s {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_s>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hml_c: ak_hml_c {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hml LALT C>;

            akt_comma_c {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_c>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hml_n: ak_hml_n {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hml LEFT_SHIFT N>;

            akt_comma_n {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_n>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hml_t: ak_hml_t {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hml LEFT_CONTROL T>;

            akt_comma_t {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_t>;
                max-prior-idle-ms = <500>;
            };
        };

        // Comma Magic for homerow-mod A
        ak_hmr_a: ak_hmr_a {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hmr LEFT_CONTROL A>;

            akt_comma_a2 {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_a>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hmr_e: ak_hmr_e {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hmr RIGHT_SHIFT E>;

            akt_comma_e {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_e>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hmr_i: ak_hmr_i {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hmr LALT I>;

            akt_comma_i {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_i>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_hmr_h: ak_hmr_h {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&hmr LEFT_GUI H>;

            akt_comma_h {
                trigger-keys = <COMMA>;
                bindings = <&comma_cap_h>;
                max-prior-idle-ms = <500>;
            };
        };

        // Trying to implement a sticky shift on tap, layer 1 on hold thing here.

        lt_sk: layer_tap_sticky_shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <150>;
            require-prior-idle-ms = <150>;
            bindings = <&mo>, <&sk>;
        };

        // Comma Magic test: typing comma then G capitalizes it (deletes the comma)
        ak_g: ak_g {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp G>;

            akt_comma_g {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(G)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_x: ak_x {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp X>;

            akt_comma_x {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(X)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_q: ak_q {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp Q>;

            akt_comma_q {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(Q)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_m: ak_m {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp M>;

            akt_comma_m {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(M)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_p: ak_p {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp P>;

            akt_comma_p {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(P)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_j: ak_j {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp J>;

            akt_comma_j {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(J)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_w: ak_w {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp W>;

            akt_comma_w {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(W)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_f: ak_f {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp F>;

            akt_comma_f {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(F)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_l: ak_l {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp L>;

            akt_comma_l {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(L)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_d: ak_d {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp D>;

            akt_comma_d {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(D)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_v: ak_v {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp V>;

            akt_comma_v {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(V)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_u: ak_u {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp U>;

            akt_comma_u {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(U)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_o: ak_o {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp O>;

            akt_comma_o {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(O)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_y: ak_y {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp Y>;

            akt_comma_y {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(Y)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_b: ak_b {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp B>;

            akt_comma_b {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(B)>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_k: ak_k {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&kp K>;

            akt_comma_k {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp LS(K)>;
                max-prior-idle-ms = <500>;
            };

            ak_r: ak_r {
                compatible = "zmk,behavior-adaptive-key";
                #binding-cells = <0>;
                bindings = <&kp R>;

                akt_comma_r {
                    trigger-keys = <COMMA>;
                    bindings = <&kp BSPC &kp LS(R)>;
                    max-prior-idle-ms = <500>;
                };
        };

        // Comma Magic for umlaut macros: comma + umlaut produces the capitalized umlaut
        ak_ae: ak_ae {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&ae_umlaut>;

            akt_comma_ae {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp RA(LS(A))>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_aa: ak_aa {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&aa_umlaut>;

            akt_comma_aa {
                trigger-keys = <COMMA>;
                bindings = <&kp BSPC &kp RA(LS(W))>;
                max-prior-idle-ms = <500>;
            };
        };

        ak_oe: ak_oe {
            compatible = "zmk,behavior-adaptive-key";
            #binding-cells = <0>;
            bindings = <&oe_umlaut>;

            akt_comma_oe {
                trigger-keys = <COMMA>;
